# SMTP-Zugangsdaten für den Versand des Kontaktformulars.
# Standardmäßig für den Versand über einen lokalen Postfix-MTA (localhost:25) vorbereitet.
# Läuft Postfix als Relay zu einem Smarthost mit Authentifizierung, SMTP_USER/SMTP_PASS setzen.

# Hostname des SMTP-Servers/Postfix-MTA. Bei lokalem Postfix auf demselben Server: "localhost".
SMTP_HOST=localhost

# Port des SMTP-Servers. Lokales Postfix (unauthentifiziert, Server-zu-Server): 25.
# Bei Submission über Postfix mit STARTTLS/Auth üblicherweise: 587.
SMTP_PORT=25

# "true", wenn der SMTP-Server implizites TLS auf dem Port erwartet (z. B. Port 465).
# Bei Postfix auf Port 25/587 in der Regel "false" lassen (STARTTLS wird automatisch verhandelt).
SMTP_SECURE=false

# Nur setzen, wenn der SMTP-Server/Postfix-Relay eine Authentifizierung verlangt.
# Bleiben beide leer, verbindet sich nodemailer ohne Authentifizierung (typisch für lokalen Postfix).
SMTP_USER=
SMTP_PASS=

# Absenderadresse der versendeten Mails. Sollte zu einer Domain gehören, für die Postfix
# senden darf (SPF/DKIM eingerichtet), z. B. no-reply@wissenskern.ai.
MAIL_FROM="WissensKern Website <no-reply@wissenskern.ai>"

# Empfängeradresse für eingehende Kontaktanfragen.
MAIL_TO=info@wissenskern.ai
